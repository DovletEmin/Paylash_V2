# ─── PostgreSQL ───
POSTGRES_DB=paylash
POSTGRES_USER=paylash
POSTGRES_PASSWORD=paylash_secret

# ─── MinIO ───
MINIO_ROOT_USER=paylash
MINIO_ROOT_PASSWORD=paylash_secret

# ─── Caddy / domain ───
# Local domain Caddy serves with an auto-issued, auto-trusted-by-Caddy
# internal certificate (no public DNS or ACME needed). Point this hostname
# at the server's IP via /etc/hosts (or local DNS) on every client machine.
PAYLASH_DOMAIN=paylash.local

# ─── Paylash App ───
PAYLASH_PORT=8080
PAYLASH_DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
PAYLASH_MINIO_ENDPOINT=minio:9000
PAYLASH_MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
PAYLASH_MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
PAYLASH_MINIO_USE_SSL=false
# Host:port the BROWSER (not the app container) can reach MinIO on directly —
# used only to sign presigned URLs for large resumable uploads, which flow
# straight from the browser to MinIO instead of through the app. Point this
# at the server's LAN address on MinIO's S3 port (published above as 9000);
# leave empty to disable large-file resumable uploads entirely.
PAYLASH_MINIO_PUBLIC_ENDPOINT=paylash.local:9000
PAYLASH_COLLABORA_URL=https://${PAYLASH_DOMAIN}
PAYLASH_BASE_URL=http://paylash-app:8080
# Set to false to close public self-registration once employees are onboarded
# via the admin panel (manual add or CSV/XLSX import) — an open registration
# endpoint on the LAN otherwise hands instant access to the company-wide
# "common" space to anyone who can reach the server.
PAYLASH_ALLOW_REGISTRATION=true
