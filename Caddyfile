{$PAYLASH_DOMAIN} {
	tls internal

	encode gzip

	request_body {
		max_size 200MB
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options SAMEORIGIN
		# Defense-in-depth: no script/style/image/media/frame may load from any
		# third-party origin (blocks the exact "external CDN" pattern the removed
		# Google Fonts dependency used, and a large class of exfiltration/backdoor
		# payloads that rely on fetching a remote resource). 'unsafe-inline' stays
		# on script-src/style-src because this frontend is built with inline
		# onclick="..." handlers and inline style="..." throughout (no build step,
		# no framework) — a real script-src without it would need rewriting every
		# handler to addEventListener first, which is its own separate project.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self'; connect-src 'self'; frame-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
	}

	# Collabora — static assets, WOPI discovery, WebSocket/API.
	# reverse_proxy preserves the original Host header and upgrades the
	# connection automatically for the ws paths, same as the old nginx config.
	@collabora path /browser/* /hosting/* /cool/* /lool/*
	reverse_proxy @collabora paylash-collabora:9980

	# Everything else (app UI, /api/, /wopi/) → the Paylash app.
	reverse_proxy paylash-app:8080
}
